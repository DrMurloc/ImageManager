@page "/add-folder"
@using System.Security.Claims
@using System.Text.RegularExpressions
@inject IMetadataStore Store
@inject IDriveScanner Drive
@inject IDriveUploader Uploader
@inject IGoogleUserTokens Tokens
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Add Commission Folder</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Add Commission Folder</MudText>

@if (_db is null || _collections is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-4" Style="max-width:640px">
        <MudSelect T="string" @bind-Value="_collectionId" Label="Collection" Dense="true" Class="mb-3">
            @foreach (var c in _collections)
            {
                <MudSelectItem T="string" Value="@c.Id">@c.Name</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="string" @bind-Value="_artistId" Label="Artist" Dense="true" Class="mb-3">
            @foreach (var a in _db.Artists)
            {
                <MudSelectItem T="string" Value="@a.Id">@a.Name</MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="_descriptor" Label="Descriptor" Immediate="true" />

        <MudText Typo="Typo.body2" Class="mt-2 mb-3 mud-text-secondary">
            New folder: <b>@SubfolderName()</b>
        </MudText>

        <MudText Typo="Typo.body2" Class="mb-1">Files (select or drag &amp; drop)</MudText>
        <MudFileUpload T="IReadOnlyList<IBrowserFile>" @bind-Files="_files" Hidden="false" />

        @if (_files is { Count: > 0 })
        {
            <MudText Typo="Typo.caption" Class="mt-2 d-block">@_files.Count file(s) selected</MudText>
        }

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-4">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.CloudUpload"
                       OnClick="Upload" Disabled="_busy">
                @(_busy ? "Uploading…" : "Upload to Drive")
            </MudButton>
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Login" OnClick="Reconnect">
                Reconnect Google
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    private CommissionDatabase? _db;
    private List<DriveFolderRef>? _collections;
    private string? _collectionId;
    private string? _artistId;
    private string _descriptor = "";
    private IReadOnlyList<IBrowserFile>? _files;
    private bool _busy;
    private string _email = "";

    protected override async Task OnInitializedAsync()
    {
        _db = await Store.LoadAsync();
        _collections = (await Drive.ListCollectionsAsync()).ToList();
        var auth = await AuthState.GetAuthenticationStateAsync();
        _email = auth.User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    }

    private string AlphaArtist()
    {
        var artist = _db?.Artists.FirstOrDefault(a => a.Id == _artistId);
        return artist is null ? "" : Regex.Replace(artist.Name, "[^A-Za-z0-9]", "");
    }

    private string SubfolderName()
    {
        var descriptor = _descriptor.Trim();
        var artist = AlphaArtist();
        return descriptor.Length == 0 && artist.Length == 0 ? "…" : $"{descriptor}_{artist}";
    }

    private void Reconnect() => Nav.NavigateTo("/login?returnUrl=/add-folder", forceLoad: true);

    private async Task Upload()
    {
        if (_db is null) return;
        if (string.IsNullOrEmpty(_collectionId)) { Snackbar.Add("Pick a collection.", Severity.Warning); return; }
        if (string.IsNullOrEmpty(_artistId)) { Snackbar.Add("Pick an artist.", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_descriptor)) { Snackbar.Add("Enter a descriptor.", Severity.Warning); return; }
        if (_files is null || _files.Count == 0) { Snackbar.Add("Select at least one file.", Severity.Warning); return; }

        var token = await Tokens.GetValidAccessTokenAsync(_email);
        if (token is null)
        {
            Snackbar.Add("Your Google connection expired — click Reconnect Google, then upload.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            var folderId = await Uploader.CreateFolderAsync(token, _collectionId!, SubfolderName());
            var uploaded = 0;
            foreach (var file in _files)
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 104_857_600);
                using var buffer = new MemoryStream();
                await stream.CopyToAsync(buffer);
                buffer.Position = 0;
                await Uploader.UploadAsync(token, folderId, file.Name, file.ContentType, buffer);
                uploaded++;
            }

            Snackbar.Add($"Uploaded {uploaded} file(s) to {SubfolderName()}.", Severity.Success);
            _files = null;
            _descriptor = "";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
