@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">Commission Image Manager</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2 d-none d-sm-flex">@context.User.Identity?.Name</MudText>
                <MudTooltip Text="Sign out">
                    <MudIconButton Color="Color.Inherit" Icon="@Icons.Material.Filled.Logout" OnClick="SignOut" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Color="Color.Inherit"
                       Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       OnClick="@(() => _isDarkMode = !_isDarkMode)" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    // Full reload so the server endpoint handles sign-out instead of the Blazor router.
    private void SignOut() => Nav.NavigateTo("/logout", forceLoad: true);
}
