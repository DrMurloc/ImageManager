@page "/chapters"
@using System.Net
@using System.Text.RegularExpressions
@inject IMetadataStore Store
@inject ISnackbar Snackbar

<PageTitle>AO3 Chapters</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">AO3 Chapters</MudText>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.Download" OnClick="OpenImport">Import from AO3</MudButton>
    <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenAdd">Add chapter</MudButton>
</MudStack>

@if (_db is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_db.Chapters.Count == 0)
{
    <MudText>No chapters yet. Add the AO3 chapters you embed images on.</MudText>
}
else
{
    <MudTable Items="_db.Chapters" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>URL</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="URL">
                <MudLink Href="@context.Url" Target="_blank">@context.Url</MudLink>
            </MudTd>
            <MudTd Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEdit(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>@(_editing is null ? "Add chapter" : "Edit chapter")</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_form.Title" Label="Title" Required="true" Placeholder="Chapter 5" />
        <MudTextField @bind-Value="_form.Url" Label="URL" Class="mt-3" Placeholder="https://archiveofourown.org/works/.../chapters/..." />
        <MudStack Row="true" Spacing="2" Class="mt-3">
            <MudNumericField @bind-Value="_form.GalleryMaxWidth" Label="Gallery max width (px)" Min="1" />
            <MudNumericField @bind-Value="_form.GalleryMaxHeight" Label="Gallery max height (px)" Min="1" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_importDialogVisible" Options="_importDialogOptions">
    <TitleContent>Import chapters from AO3</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_importWorkRef" Label="Work URL or ID (optional)"
                      Placeholder="https://archiveofourown.org/works/67228336 — or just 67228336" />
        <MudTextField @bind-Value="_importHtml" Label="Paste the chapter <select> HTML" Lines="8" Class="mt-3"
                      Placeholder="<select ...><option value=&quot;...&quot;>1. Prologue</option>...</select>" />
        <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">
            On the AO3 work page, right-click the chapter dropdown → Inspect, then copy the &lt;select&gt; element.
            With a work URL/ID, each chapter gets a direct link; without it, only titles are imported.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _importDialogVisible = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="RunImport">Import</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private CommissionDatabase? _db;
    private bool _dialogVisible;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private Ao3Chapter? _editing;
    private Ao3Chapter _form = new();

    private bool _importDialogVisible;
    private readonly DialogOptions _importDialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private string _importWorkRef = "";
    private string _importHtml = "";

    protected override async Task OnInitializedAsync() => _db = await Store.LoadAsync();

    private void OpenImport()
    {
        _importWorkRef = "";
        _importHtml = "";
        _importDialogVisible = true;
    }

    private async Task RunImport()
    {
        if (_db is null) return;
        if (string.IsNullOrWhiteSpace(_importHtml))
        {
            Snackbar.Add("Paste the <select> HTML first.", Severity.Warning);
            return;
        }

        var workId = ExtractWorkId(_importWorkRef);
        var added = 0;
        foreach (Match m in Regex.Matches(_importHtml, "<option[^>]*value=\"(\\d+)\"[^>]*>(.*?)</option>", RegexOptions.Singleline))
        {
            var chapterId = m.Groups[1].Value;
            var title = WebUtility.HtmlDecode(m.Groups[2].Value).Trim();
            if (title.Length == 0) continue;

            var url = workId is null ? "" : $"https://archiveofourown.org/works/{workId}/chapters/{chapterId}";
            var exists = url.Length > 0
                ? _db.Chapters.Any(c => c.Url == url)
                : _db.Chapters.Any(c => string.Equals(c.Title, title, StringComparison.OrdinalIgnoreCase));
            if (exists) continue;

            _db.Chapters.Add(new Ao3Chapter { Title = title, Url = url });
            added++;
        }

        if (added > 0) await Store.SaveAsync(_db);
        _importDialogVisible = false;
        Snackbar.Add(added == 0 ? "No new chapters found." : $"Imported {added} chapter(s).",
            added == 0 ? Severity.Info : Severity.Success);
    }

    private static string? ExtractWorkId(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var m = Regex.Match(input, "works/(\\d+)");
        if (m.Success) return m.Groups[1].Value;
        var trimmed = input.Trim();
        return Regex.IsMatch(trimmed, "^\\d+$") ? trimmed : null;
    }

    private void OpenAdd()
    {
        _editing = null;
        _form = new Ao3Chapter();
        _dialogVisible = true;
    }

    private void OpenEdit(Ao3Chapter chapter)
    {
        _editing = chapter;
        _form = new Ao3Chapter
        {
            Id = chapter.Id,
            Title = chapter.Title,
            Url = chapter.Url,
            GalleryMaxWidth = chapter.GalleryMaxWidth,
            GalleryMaxHeight = chapter.GalleryMaxHeight
        };
        _dialogVisible = true;
    }

    private async Task Save()
    {
        if (_db is null) return;
        if (string.IsNullOrWhiteSpace(_form.Title))
        {
            Snackbar.Add("Title is required.", Severity.Warning);
            return;
        }

        if (_editing is null)
        {
            _db.Chapters.Add(_form);
        }
        else
        {
            _editing.Title = _form.Title;
            _editing.Url = _form.Url;
            _editing.GalleryMaxWidth = _form.GalleryMaxWidth;
            _editing.GalleryMaxHeight = _form.GalleryMaxHeight;
        }

        await Store.SaveAsync(_db);
        _dialogVisible = false;
        Snackbar.Add("Saved.", Severity.Success);
    }

    private async Task Delete(Ao3Chapter chapter)
    {
        if (_db is null) return;
        _db.Chapters.Remove(chapter);
        foreach (var group in _db.Groups)
            foreach (var image in group.Images)
            {
                image.Ao3ChapterIds.Remove(chapter.Id);
                image.AddedToChapterIds.Remove(chapter.Id);
                image.ChapterSections.Remove(chapter.Id);
            }
        await Store.SaveAsync(_db);
        Snackbar.Add("Deleted.", Severity.Success);
    }
}
